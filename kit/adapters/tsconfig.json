{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "Bundler",
    "strict": true, "exactOptionalPropertyTypes": true, "noUncheckedIndexedAccess": true,
    "noEmit": true, "esModuleInterop": true, "skipLibCheck": true, "lib": ["ES2022", "DOM"]
  },
  "include": ["*.ts"]
}
